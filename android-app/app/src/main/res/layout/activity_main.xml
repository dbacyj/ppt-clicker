<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- 顶部：模式标签 + 状态条 -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/modeLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:text="蓝牙 · 免安装" />

            <ImageButton
                android:id="@+id/menuBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_more"
                android:contentDescription="@string/menu_switch_mode"
                app:tint="@color/text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="10dp"
            android:background="@color/bg_card"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            tools:text="就绪：在电脑蓝牙里搜索并配对 PPT Clicker" />
    </LinearLayout>

    <!-- 中部：两个大翻页按钮 -->
    <LinearLayout
        android:id="@+id/navButtons"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/auxButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/prevBtn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:backgroundTint="@color/btn_prev"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:text="@string/btn_prev" />

        <Button
            android:id="@+id/nextBtn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/btn_next"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:text="@string/btn_next" />
    </LinearLayout>

    <!-- 底部：辅助功能按钮网格 -->
    <GridLayout
        android:id="@+id/auxButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:columnCount="3"
        android:useDefaultMargins="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button android:id="@+id/fullscreenBtn" style="@style/AuxButton"
            android:text="@string/btn_fullscreen" />
        <Button android:id="@+id/exitBtn" style="@style/AuxButton"
            android:text="@string/btn_exit" />
        <Button android:id="@+id/blackBtn" style="@style/AuxButton"
            android:text="@string/btn_black" />
        <Button android:id="@+id/whiteBtn" style="@style/AuxButton"
            android:text="@string/btn_white" />
        <Button android:id="@+id/homeBtn" style="@style/AuxButton"
            android:text="@string/btn_home" />
        <Button android:id="@+id/endBtn" style="@style/AuxButton"
            android:text="@string/btn_end" />
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
